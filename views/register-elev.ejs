<%- include('partials/header') %>

<h1>Registrer elev</h1>
<p>Legg til en elev i en valgt bedrift.</p>

<form action="/bedrift/register-elev" method="POST">
  <label for="name">Navn</label>
  <input id="name" type="text" name="name" value="<%= typeof name !== 'undefined' ? name : '' %>" required />

  <label for="email">E-post</label>
  <input id="email" type="email" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>" required />

  <label for="bedriftId">Bedrift</label>
  <select id="bedriftId" name="bedriftId" required>
    <option value="">Velg bedrift</option>
    <% if (Array.isArray(bedrifter)) { %>
      <% bedrifter.forEach((bedrift) => { %>
        <option value="<%= bedrift._id %>" <%= typeof bedriftId !== 'undefined' && bedriftId === String(bedrift._id) ? 'selected' : '' %>>
          <%= bedrift.name %> (<%= bedrift.type %>)
        </option>
      <% }) %>
    <% } %>
  </select>

  <label for="stayDurationDays">Varighet i bedrift (dager)</label>
  <input
    id="stayDurationDays"
    type="number"
    name="stayDurationDays"
    min="1"
    value="<%= typeof stayDurationDays !== 'undefined' ? stayDurationDays : 30 %>"
    required
  />
  <small>Normal drift: bruk dager.</small>

  <label for="stayDurationMinutesTest">Testmodus: utlop om X minutter (valgfritt)</label>
  <input
    id="stayDurationMinutesTest"
    type="number"
    name="stayDurationMinutesTest"
    min="1"
    value="<%= typeof stayDurationMinutesTest !== 'undefined' ? stayDurationMinutesTest : '' %>"
  />
  <small>Hvis fylt ut, overstyrer denne dager-feltet kun for testing.</small>

  <% if (!Array.isArray(bedrifter) || bedrifter.length === 0) { %>
    <p class="message error">Du har ingen bedrifter ennå. Opprett en først.</p>
  <% } %>

  <button type="submit">Registrer elev</button>
</form>

<% if (typeof error !== "undefined") { %>
  <p class="message error"><%= error %></p>
<% } %>

<% if (typeof success !== "undefined") { %>
  <p class="message success"><%= success %></p>
<% } %>

<%- include('partials/footer') %>